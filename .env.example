# Your Discord User Token (Not Bot Token)
# WARNING: Keep this secret! Do not share it with anyone.
USER_TOKEN=your_discord_user_token_here

# The ID of the channel where you are fishing
CHANNEL_ID=your_channel_id_here

# Time to wait between /fish commands in seconds.
# (It's different per level, just spam fish again to see the number)
WAIT_TIME=2.2

# (OPTIONAL) Google AI Studio API Key for Auto-OCR Image Captchas
# Get one here: https://aistudio.google.com/
# Note: The API key is 100% FREE! We use the completely free Gemini tier for this.
# If not set, the bot will parse text captchas normally, but will pause for image captchas.
GEMINI_API_KEY=your_gemini_api_key_here